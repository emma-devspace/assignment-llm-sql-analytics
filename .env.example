OPENROUTER_API_KEY=<OPENROUTER_API_KEY>
# Optional: override the default model (openai/gpt-4.1-nano)
# OPENROUTER_MODEL=openai/gpt-4.1-nano
# For free tier: OPENROUTER_MODEL=openrouter/free

# Optional: comma-separated fallback models if the primary model fails
# OPENROUTER_FALLBACK_MODELS=google/gemini-2.0-flash-lite:free

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
